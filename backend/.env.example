PORT=5000

# --- MongoDB (choose ONE option) ---

# Option A: Local MongoDB (install MongoDB Community on your PC)
MONGODB_URI=mongodb://localhost:27017/sslms

# Option B: MongoDB Atlas (cloud — recommended for Windows)
# MONGODB_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/sslms?retryWrites=true&w=majority

JWT_SECRET=your_jwt_secret_key_change_in_production
JWT_EXPIRE=30d
